<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="4dp">

    <!-- Reusable button style size -->
    
    <!-- H1 -->
    <ImageButton
        android:id="@+id/action_h1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_marker"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="H1" />

    <ImageButton
        android:id="@+id/action_h2"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_marker"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="H2" />

    <ImageButton
        android:id="@+id/action_h3"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_marker"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="H3" />

    <ImageButton
        android:id="@+id/action_bold"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_bold"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Bold" />

    <ImageButton
        android:id="@+id/action_Italic"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_italic"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Italic" />

    <ImageButton
        android:id="@+id/action_indent"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_indent"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Indent" />

    <ImageButton
        android:id="@+id/action_outdent"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_outdent"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Outdent" />

    <ImageButton
        android:id="@+id/action_blockquote"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_marker"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Blockquote" />

    <ImageButton
        android:id="@+id/action_bulleted"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_bullet_list"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Bullet List" />

    <ImageButton
        android:id="@+id/action_unordered_numbered"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_numbered_list"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Numbered List" />

    <ImageButton
        android:id="@+id/action_hr"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_hr"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Divider" />

    <ImageButton
        android:id="@+id/action_color"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_marker"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Text Color" />

    <ImageButton
        android:id="@+id/action_insert_image"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_image"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Insert Image" />

    <ImageButton
        android:id="@+id/action_insert_link"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_link"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Insert Link" />

    <ImageButton
        android:id="@+id/action_erase"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_erase"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Clear All" />

</LinearLayout>